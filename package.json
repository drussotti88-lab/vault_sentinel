{
  "name": "sentinel",
  "version": "0.1.0",
  "private": true,
  "description": "Stock Checkers (codename Sentinel) — self-hosted Discord stock-alert system",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "worker": "tsx src/index.ts",
    "bot": "tsx src/bot/index.ts",
    "register-commands": "tsx src/bot/register.ts",
    "test": "node --test --import tsx ./src/**/*.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
